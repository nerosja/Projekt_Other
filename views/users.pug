//nutzer seite
doctype html
html
    head
        title OTHer
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        // Bootstrap CSS
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
        // Bootstrap Icons
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css")
        //Icon für Browser Tab
        link(rel="icon"  href="/img/logo.svg")
        link(rel="stylesheet", href="/css/style.css")
        link(href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet")

body
    nav
        include Navigation

    .container
        .left-navigation
            include leftside

        .allUser
            each user in users
                .col
                    .card
                        if user.profile_pic
                            img(src='/img/users/' + user.profile_pic+ ".png", alt='Profilbild')

                        .card-body
                            .nameAndName
                                h5.card-title
                                  a(href=`/profile/${user.user_id}`)| #{user.name}
                                span.text-muted  &nbsp   @#{user.name}
                            p.text-muted User-ID: #{user.user_id}
                            //ähnlich wie bei othern.pug
                        form.follow-form(method="POST", action="/follow", class="mb-2")
                            input(type="hidden", name="followee", value=user.user_id)
                            if user.user_id === currentUserId
                                button.btn.btn-secondary(disabled=true) Du selbst
                            else if user.is_followed
                                button.btn.btn-warning(type="submit", data-action="unfollow") Entfolgen
                            else
                                button.btn.btn-primary(type="submit", data-action="follow") Folgen
script(src="https://code.jquery.com/jquery-3.6.0.min.js")
script(src="FolgenEntfolgen.js")
// FolgenEntfolgen.js ist in /public
//zeigt alle Nutzer in /users an